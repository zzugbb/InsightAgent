INSIGHT_AGENT_ENV=development
INSIGHT_AGENT_MODE=mock
INSIGHT_AGENT_PROVIDER=mock
INSIGHT_AGENT_MODEL=mock-gpt
INSIGHT_AGENT_BASE_URL=
INSIGHT_AGENT_API_KEY=
# OpenAI-compatible 示例：
# DeepSeek: INSIGHT_AGENT_BASE_URL=https://api.deepseek.com/v1
# Z-AI(智谱): INSIGHT_AGENT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
INSIGHT_AGENT_DATABASE_URL=postgresql://insight:insight@127.0.0.1:5432/insightagent

# Chroma（docker compose 默认 8001:8000；仅本机 backend 时用 127.0.0.1）
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001
# 设为 false 时 /health 中 chroma.reachable 为 null，不发起网络探测
CHROMA_PROBE=true

# RAG（W4）
RAG_DEFAULT_KNOWLEDGE_BASE_ID=default
RAG_DEFAULT_TOP_K=4

# usage / cost 估算（USD）
USAGE_PROMPT_TOKEN_PRICE_PER_1K=0.001
USAGE_COMPLETION_TOKEN_PRICE_PER_1K=0.002

# 鉴权与密钥加密（阶段 5）
INSIGHT_AGENT_JWT_SECRET=change-me-in-production
INSIGHT_AGENT_ACCESS_TOKEN_TTL_MINUTES=10080
INSIGHT_AGENT_REFRESH_TOKEN_TTL_DAYS=30
INSIGHT_AGENT_SECRET_KEY=
